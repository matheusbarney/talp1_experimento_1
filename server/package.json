{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test:acceptance": "cucumber-js \"tests/acceptance/features/**/*.feature\" --import \"tests/acceptance/steps/**/*.js\" --format progress",
    "test:acceptance:dry": "cucumber-js \"tests/acceptance/features/**/*.feature\" --import \"tests/acceptance/steps/**/*.js\" --format progress --dry-run",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "@types/multer": "^2.1.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "express": "^4.19.2",
    "jszip": "^3.10.1",
    "multer": "^2.1.1",
    "pdf-lib": "^1.17.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "prisma": "^6.7.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
